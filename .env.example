# Copy this file to `.env` and fill in any values you want to override.
# All variables below are OPTIONAL — the pipeline runs without them.
#
# Load into your shell with: `set -a && source .env && set +a`
# (uv automatically inherits exported env vars.)


# ─── NCBI E-utilities (Phases 2 + 3 — PubMed ingest) ────────────────────────

# Free key from https://www.ncbi.nlm.nih.gov/account/settings/
# Without it: rate-limited to 3 requests/second.
# With it:    10 requests/second (Phases 2 + 3 ~3x faster).
NCBI_API_KEY=

# Contact email NCBI requires in every E-utilities request. Overrides
# the default in config/pipeline.yaml. Use your own when forking.
NCBI_EMAIL=


# ─── Hugging Face (Phase 5 — BGE; Phase 7+ — DeepSeek model download) ───────

# Free token from https://huggingface.co/settings/tokens
# Optional but recommended — anonymous downloads can be rate-limited
# and slower, especially for the ~28 GB DeepSeek-R1-Distill weights.
HF_TOKEN=

# Where to cache downloaded model weights. Default: ./.hf_cache (in
# the repo). Move to a larger volume if your home dir is small.
# scripts/start_vllm_server.sh and the embedding code both honor this.
HF_HOME=
