# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# uv / virtualenv
.venv/
.python-version.local

# Local config overrides
.env
.env.local
*.env

# Hugging Face model cache (BGE ~5 GB, DeepSeek ~28 GB)
.hf_cache/
.cache/huggingface/

# Per-phase runtime logs (regenerable; per-run timestamped)
logs/

# ---- Regenerable pipeline data ----------------------------------------
# All of this is rebuilt by scripts/bootstrap.sh from PubMed + the
# embedding model. Do NOT commit — keeps the repo small (a clean
# clone is < 5 MB) and avoids stale snapshots.

# Phase 2: ESummary metadata
db/discovery.jsonl
db/discovery.jsonl.tmp

# Phase 3: raw EFetch XML + normalized JSON
db/raw/
db/parsed/

# Phase 4: chunked text
db/chunks/

# Phase 5: Chroma persistent index
index/chroma/

# Phase 6: manifest (auto-regenerated by ingest.manifest)
db/manifest.jsonl
db/manifest.jsonl.tmp

# ---- Things we DO commit ---------------------------------------------
# (listed here so a contributor reading .gitignore knows what's intentional)
#  - clinicomm/                 source
#  - scripts/                   CLIs
#  - config/                    pipeline.yaml + prompts
#  - demos/synthetic_patients/  3 hand-authored transcripts
#  - manuscript/figures_ascii/  ASCII figure drafts (Phase 12)
#  - manuscript/tables_draft/   auto-generated tables (Phase 12)
#  - manuscript/traces/         example pipeline traces + comparisons
#  - pyproject.toml + uv.lock   pinned deps
#  - README.md, CHANGELOG, .env.example
